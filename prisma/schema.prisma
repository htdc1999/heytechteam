generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Models

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  dashboardLayout String?
  accounts      Account[]
  sessions      Session[]
  changeLogs    ChangeLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Custom Models

model Client {
  id        String   @id @default(cuid())
  name      String
  gbpFocusKeyword String?
  clientNotes     String?
  gbpPostsScheduledUntil DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  changeLogs ChangeLog[]
  mediaFiles MediaFile[]
  onboardingTasks OnboardingTask[]
  auditTasks AuditTask[]
  gbpDocuments GbpDocument[]
}

model ChangeLog {
  id          String   @id @default(cuid())
  action      String   // e.g. "ADD", "DELETE", "UPDATE"
  entity      String   // e.g. "CLIENT", "GBP_POST", etc.
  entityId    String?  // ID of affected entity
  details     String?  // JSON string of changes
  timestamp   DateTime @default(now())
  userId      String
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?  @relation(fields: [entityId], references: [id], onDelete: SetNull)
}

model MediaFile {
  id          String   @id @default(cuid())
  type        String
  link        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model OnboardingTask {
  id          String   @id @default(cuid())
  taskName    String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model AuditTask {
  id           String    @id @default(cuid())
  taskName     String
  lastWorkedOn DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model GbpDocument {
  id        String   @id @default(cuid())
  type      String   // "POSTS" | "OPTIMIZATIONS"
  title     String
  link      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Global Dashboard Data Models

model GlobalNote {
  id        String   @id @default("global")
  content   String   @default("")
  updatedAt DateTime @updatedAt
}

model GlobalTask {
  id          String   @id @default(cuid())
  taskName    String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GlobalGbpDocument {
  id        String   @id @default(cuid())
  title     String
  link      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalEmailTemplate {
  id        String   @id @default(cuid())
  title     String
  link      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalGoogleAdsClient {
  id        String   @id @default(cuid())
  title     String
  link      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
